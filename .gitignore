# venvs
.venv/
venv/
env/

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ocode runtime data
.ocode/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Secrets / local config
.env
.env.*
!.env.example
*.pem
*.key

# Tooling session state — never commit
.claude/
.tmp-*

# Nested external projects (own repo / contains its own .env)
RedTeam-MCP/

# Transient coverage snapshots
coverage_*.json

# Large model artifacts (if checkpoints land in tree)
*.gguf
*.safetensors
*.bin
*.ckpt

# Phase 16 bench results — transient timestamped files
tests/fixtures/benchmarks/results/*.json

# Phase 17 stress harness — synthesizes a profile root, never commit
stress-home/

# T4-01 vision fixtures — synthesised deterministically at test
# collection time by tests/vision/fixtures/__init__.py; checking
# them in would just be churn on every Pillow upgrade.
tests/vision/fixtures/*.jpg
tests/vision/fixtures/*.png

# T4-02 video fixtures — synthesised lazily by
# tests/video/fixtures/__init__.py when ffmpeg is available
# (consumer tests skip cleanly when it isn't). Synthesised from
# ffmpeg's deterministic testsrc filter — same reproducibility
# story as the vision fixtures.
tests/video/fixtures/*.mp4
tests/video/fixtures/*.mov

# Dogfood / debug logs captured at the repo root (e.g.
# ``athena 2>&1 | Tee-Object athena-log.txt``). Operator-generated;
# never source.
/athena-log.txt
/athena-*.log
coverage.json

# Local-only: test plans, runbooks, and internal planning/recon notes.
# These are working artifacts, not shippable docs — they stay on disk
# but never get committed to the public repo. The *_PLAN.md / *RECON.md
# globs make the policy hold for future files automatically.
*-pytest.txt
/pytest-out.txt
*_PLAN.md
*RECON.md
RUNBOOK.md
TUI_SPRINT.md
PHASE_1_BASELINE.md
transform/PIPELINE.md
athena/goal/LOOP_NOTES.md
athena/providers/CAPABILITY_NOTES.md
docs/manual-test-suite.md
docs/user-driven-test-plan.md

# Local-only: agent guidance + per-version release notes. Kept on disk
# (Claude Code reads CLAUDE.md locally) but not shipped in the public repo.
/CLAUDE.md
/RELEASE_v*.md
