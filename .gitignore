# venvs
.venv/
venv/
env/

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ocode runtime data
.ocode/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Secrets / local config
.env
.env.*
*.pem
*.key

# Tooling session state — never commit
.claude/
.tmp-*

# Nested external projects (own repo / contains its own .env)
RedTeam-MCP/

# Transient coverage snapshots
coverage_*.json

# Large model artifacts (if checkpoints land in tree)
*.gguf
*.safetensors
*.bin
*.ckpt

# Phase 16 bench results — transient timestamped files
tests/fixtures/benchmarks/results/*.json

# Phase 17 stress harness — synthesizes a profile root, never commit
stress-home/

# T4-01 vision fixtures — synthesised deterministically at test
# collection time by tests/vision/fixtures/__init__.py; checking
# them in would just be churn on every Pillow upgrade.
tests/vision/fixtures/*.jpg
tests/vision/fixtures/*.png

# T4-02 video fixtures — synthesised lazily by
# tests/video/fixtures/__init__.py when ffmpeg is available
# (consumer tests skip cleanly when it isn't). Synthesised from
# ffmpeg's deterministic testsrc filter — same reproducibility
# story as the vision fixtures.
tests/video/fixtures/*.mp4
tests/video/fixtures/*.mov
